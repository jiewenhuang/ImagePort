{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "singleQuote": true,
  "semi": true,
  "trailingComma": "none",
  "useTabs": true,
  "tabWidth": 2,
  "svelte": true,
  "ignorePatterns": [
    ".svelte-kit/**",
    "build/**",
    "node_modules/**",
    "src-tauri/**"
  ]
}
