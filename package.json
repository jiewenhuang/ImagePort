{
	"name": "imageport-desktop",
	"version": "0.1.4",
	"description": "A desktop image generation workspace for OpenAI-compatible APIs, local history, references, masks, and agent-assisted creative flows.",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"format": "oxfmt --write src package.json svelte.config.js vite.config.js",
		"format:check": "oxfmt --check src package.json svelte.config.js vite.config.js",
		"lint:oxc": "oxlint --deny-warnings src svelte.config.js vite.config.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "tauri"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.3.0",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-fs": "^2.5.1",
		"@tauri-apps/plugin-sql": "^2.4.0",
		"@tauri-apps/plugin-store": "^2.4.3",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.9.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tauri-apps/cli": "^2",
		"@types/node": "^25.9.1",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"mode-watcher": "^1.1.0",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~5.6.2",
		"vite": "^6.0.3"
	}
}
