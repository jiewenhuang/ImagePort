{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "builtin": true,
    "node": true,
    "svelte": true
  },
  "plugins": ["typescript", "unicorn", "oxc"],
  "ignorePatterns": [
    ".svelte-kit/**",
    "build/**",
    "node_modules/**",
    "src-tauri/**"
  ],
  "overrides": [
    {
      "files": ["*.svelte", "**/*.svelte"],
      "rules": {
        "no-unassigned-vars": "off"
      }
    }
  ]
}
